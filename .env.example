# Dashboard Authentication
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your_secure_password_here

# Session Secret (generate a random string for production)
SESSION_SECRET=your_random_session_secret_here

# HTTPS Settings (set to true only when deploying with HTTPS/SSL)
HTTPS_ENABLED=false

# ============================================
# Storage Configuration
# ============================================
# Storage hierarchy:
# 1. Component-specific env var (e.g., WHITELIST_STORAGE)
# 2. GLOBAL_STORAGE (fallback for all components)
# 3. Default: 'file'
#
# Options: 'file' or 'mongodb'

# Global storage type (applies to all components unless overridden)
GLOBAL_STORAGE=file

# MongoDB connection (required if any component uses 'mongodb')
MONGO_URI=mongodb://localhost:27017/whatsapp-bot

# Component-specific storage (optional overrides)
# Uncomment and set to override GLOBAL_STORAGE for specific components

# CREDENTIALS_STORAGE=file         # WhatsApp credentials (creds.json)
# WHITELIST_STORAGE=file           # AI whitelist
# MEMORY_STORAGE=file              # Conversation memory
# USERSTORE_STORAGE=file           # Contact cache (user-store.json)
# WACHAN_SETTINGS_STORAGE=file     # Wachan bot settings
# AI_SETTINGS_STORAGE=file         # AI default settings (model, quota, reset, API config)

# ============================================
# Bot Configuration
# ============================================

# Bot Owner (for admin-only commands)
OWNER_ID=6212345678910@s.whatsapp.net

# ============================================
# AI Configuration
# ============================================
# IMPORTANT: These are FALLBACK values only.
# Once you configure API settings via Dashboard → AI Settings,
# the dashboard values take precedence and these env vars are ignored.
# This allows runtime configuration without editing .env file.

# AI API Key (OpenAI or Anthropic compatible)
AI_API_KEY=your_ai_api_key_here

# AI API Endpoint (optional - defaults to ai2.adevdev.com if not set)
# Useful for custom proxy or different AI provider
# AI_API_ENDPOINT=ai2.adevdev.com

# EXA API Key (OPTIONAL - EXA has a free tier without API key)
# The web search tool works fine without this using EXA's free tier
# Set this only if you have a paid EXA API key for higher rate limits
# EXA_API_KEY=your_exa_api_key_here

# ============================================
# External API
# ============================================

# Bot API Secret Key (for external API endpoints)
BOT_API_SECRET=your-secret-key-change-this

# Bot Domain (public URL for serving temporary files)
# Example: https://bot.yourdomain.com or http://localhost:3000 (for local development)
# Required for: HD command (image enhancement)
BOT_DOMAIN=https://bot.yourdomain.com
