# Dashboard Authentication
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your_secure_password_here

# Session Secret (generate a random string for production)
SESSION_SECRET=your_random_session_secret_here

# HTTPS Settings (set to true only when deploying with HTTPS/SSL)
HTTPS_ENABLED=false

# Credentials Storage (file or mongodb)
CREDS_STORAGE=file
MONGO_URI=mongodb://localhost:27017/whatsapp-bot

# Bot Owner (for admin-only commands)
OWNER_ID=6212345678910@s.whatsapp.net
